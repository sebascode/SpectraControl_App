{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for SpectraControl's custom titlebar (drag, minimize, close) and in-app updater.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "updater:default",
    "process:allow-exit",
    "notification:default",
    "dialog:default",
    "autostart:default"
  ]
}
