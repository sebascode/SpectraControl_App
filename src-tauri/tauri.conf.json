{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpectraControl",
  "version": "0.1.0",
  "identifier": "dev.spectracontrol",
  "build": {
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000",
    "beforeDevCommand": "./backend/spectractl -addr :8000",
    "beforeBuildCommand": "export PATH=/home/linuxbrew/.linuxbrew/bin:$PATH && cd backend && go build -ldflags='-s -w' -o spectractl ."
  },
  "app": {
    "windows": [
      {
        "title": "SpectraControl",
        "width": 420,
        "height": 700,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../backend/spectractl": "backend/spectractl",
      "../frontend/*": "frontend/",
      "../frontend/**/*": "frontend/"
    }
  }
}
