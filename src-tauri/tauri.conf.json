{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpectraControl",
  "version": "0.2.3",
  "identifier": "dev.spectracontrol",
  "build": {
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000",
    "beforeDevCommand": "./backend/spectractl -addr :8000",
    "beforeBuildCommand": "export PATH=/home/linuxbrew/.linuxbrew/bin:$PATH && cd backend && go build -ldflags=\"-s -w -X main.Version=${SPECTRA_VERSION:-dev}\" -o spectractl ."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpectraControl",
        "width": 420,
        "height": 700,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/spectractl": "backend/spectractl",
      "../frontend/*": "frontend/",
      "../frontend/**/*": "frontend/"
    }
  }
}
